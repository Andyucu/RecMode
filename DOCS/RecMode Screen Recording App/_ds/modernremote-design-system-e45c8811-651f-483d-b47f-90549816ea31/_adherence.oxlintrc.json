{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/disclosure/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/overlays/**",
              "components/surfaces/**",
              "ui_kits/modernremote/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Segoe UI Variable|Segoe UI Variable Display|Cascadia Code))/i]",
        "message": "Font not provided by the design system. Available: Segoe UI Variable, Segoe UI Variable Display, Cascadia Code."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconFilled|iconPosition|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconFilled, iconPosition, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconPosition'] > Literal[value!=/^(?:start|end)$/]",
        "message": "<Button> iconPosition must be one of 'start' | 'end'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|flat|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, description, flat, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|children|className|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, disabled, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComboBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|placeholder|disabled|label|className|key|ref|className|style|children)$/]",
        "message": "<ComboBox> doesn't accept that prop. Declared props: value, placeholder, disabled, label, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Expander'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|defaultOpen|open|onToggle|children|key|ref|className|style|children)$/]",
        "message": "<Expander> doesn't accept that prop. Declared props: icon, title, description, defaultOpen, open, onToggle, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|filled|label|className|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, filled, label, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconFilled|size|tone|label|disabled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, iconFilled, size, tone, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|children|key|ref|className|style|children)$/]",
        "message": "<InfoBadge> doesn't accept that prop. Declared props: variant, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|title|message|actions|onClose|icon|key|ref|className|style|children)$/]",
        "message": "<InfoBar> doesn't accept that prop. Declared props: severity, title, message, actions, onClose, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuItemSpec'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|shortcut|danger|separator|onClick|key|ref|className|style|children)$/]",
        "message": "<MenuItemSpec> doesn't accept that prop. Declared props: label, icon, shortcut, danger, separator, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|step|onChange|className|key|ref|className|style|children)$/]",
        "message": "<NumberBox> doesn't accept that prop. Declared props: value, min, max, step, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|key|ref|className|style|children)$/]",
        "message": "<ProgressRing> doesn't accept that prop. Declared props: value, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|disabled|key|ref|className|style|children)$/]",
        "message": "<RadioOption> doesn't accept that prop. Declared props: value, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='SettingsCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconFilled|title|description|action|key|ref|className|style|children)$/]",
        "message": "<SettingsCard> doesn't accept that prop. Declared props: icon, iconFilled, title, description, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|step|onChange|className|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: value, min, max, step, onChange, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|ring|size|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, ring, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|activeId|onSelect|onClose|key|ref|className|style|children)$/]",
        "message": "<TabStrip> doesn't accept that prop. Declared props: tabs, activeId, onSelect, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|type|icon|disabled|label|className|inputProps|key|ref|className|style|children)$/]",
        "message": "<TextBox> doesn't accept that prop. Declared props: value, onChange, placeholder, type, icon, disabled, label, className, inputProps."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToggleSwitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|children|className|key|ref|className|style|children)$/]",
        "message": "<ToggleSwitch> doesn't accept that prop. Declared props: checked, onChange, disabled, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:content|children|className|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: content, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TreeItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|iconFilled|depth|open|selected|hasChildren|status|onToggle|onSelect|key|ref|className|style|children)$/]",
        "message": "<TreeItem> doesn't accept that prop. Declared props: label, icon, iconFilled, depth, open, selected, hasChildren, status, onToggle, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='TreeView'] > JSXAttribute > JSXIdentifier[name!=/^(?:nodes|defaultOpen|selectedId|onSelect|onActivate|key|ref|className|style|children)$/]",
        "message": "<TreeView> doesn't accept that prop. Declared props: nodes, defaultOpen, selectedId, onSelect, onActivate."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
