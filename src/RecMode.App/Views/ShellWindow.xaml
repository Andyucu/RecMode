<Window x:Class="RecMode.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RecMode"
        Height="520" Width="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Ideal">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextBrush}"
                       FontSize="28" FontWeight="SemiBold" />
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="10,3"
                    VerticalAlignment="Center" Margin="14,4,0,0">
                <TextBlock Text="{Binding StatusPill}" Foreground="{StaticResource AccentBrush}"
                           FontSize="12" FontWeight="SemiBold" />
            </Border>
        </StackPanel>

        <TextBlock Grid.Row="1" Foreground="{StaticResource SubtleTextBrush}" FontSize="13"
                   Margin="0,4,0,20" Text="Phase 0 — foundation is up. This screen confirms the scaffolding is wired." />

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock Text="{Binding ModeLine}" Foreground="{StaticResource TextBrush}" FontSize="15" Margin="0,0,0,8" />
                <TextBlock Text="{Binding OsLine}" Foreground="{StaticResource TextBrush}" FontSize="15" Margin="0,0,0,8" />
                <TextBlock Text="{Binding FfmpegLine}" Foreground="{StaticResource TextBrush}" FontSize="15" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ThemeLine}" Foreground="{StaticResource TextBrush}" FontSize="15" Margin="0,0,0,8" />
                <TextBlock Text="{Binding RecoveryLine}" Foreground="{StaticResource TextBrush}" FontSize="15" Margin="0,0,0,16" />
                <TextBlock Text="Data folder" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" />
                <TextBlock Text="{Binding DataLocation}" Foreground="{StaticResource SubtleTextBrush}"
                           FontFamily="Cascadia Code, Consolas" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,16,0,0"
                   Text="RecMode · .NET 10 · WPF — next: Phase 0.5 pipeline spike" />
    </Grid>
</Window>
