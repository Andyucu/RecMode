<Window x:Class="RecMode.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:RecMode.App.ViewModels"
        xmlns:views="clr-namespace:RecMode.App.Views"
        xmlns:res="clr-namespace:RecMode.App.Resources"
        Title="RecMode" Height="720" Width="1120" MinHeight="520" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:RecordViewModel}"><views:RecordView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LibraryViewModel}"><views:LibraryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScheduleViewModel}"><views:ScheduleView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Title bar ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="RecMode" Style="{StaticResource BodyStrongText}"
                       VerticalAlignment="Center" Margin="16,0,0,0" />

            <Border Grid.Column="1" Background="{DynamicResource SurfaceCardBrush}" BorderBrush="{DynamicResource StrokeCardBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="10,3" VerticalAlignment="Center" Margin="12,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource TextTertiaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Record.IsRecording}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource CriticalBrush}" />
                                    </DataTrigger>
                                    <!-- Recording pulse (design: rm-blink 1.2s infinite — opacity 1 → 0.25, stops while paused) -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Record.IsRecording}" Value="True" />
                                            <Condition Binding="{Binding Record.IsPaused}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="TitleBarDotBlink">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.66" Value="0.25" />
                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:1.2" Value="0.25" />
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                        <MultiDataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="TitleBarDotBlink" />
                                        </MultiDataTrigger.ExitActions>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Record.StatusText}" Style="{StaticResource CaptionText}"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Theme toggle + caption buttons -->
            <Button Grid.Column="3" Content="◐" Command="{Binding ToggleThemeCommand}" ToolTip="Toggle theme"
                    AutomationProperties.Name="Toggle theme"
                    WindowChrome.IsHitTestVisibleInChrome="True" Width="40" Height="32" VerticalAlignment="Center"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />

            <StackPanel Grid.Column="4" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinButton" Content="&#xE921;" Click="OnMinimize" AutomationProperties.Name="Minimize" Style="{StaticResource CaptionButton}" />
                <Button x:Name="MaxButton" Content="&#xE922;" Click="OnMaximizeRestore" AutomationProperties.Name="Maximize" Style="{StaticResource CaptionButton}" />
                <Button x:Name="CloseButton" Content="&#xE8BB;" Click="OnClose" AutomationProperties.Name="Close" Style="{StaticResource CaptionCloseButton}" />
            </StackPanel>
        </Grid>

        <!-- ===== Body: sidebar (Layout=Sidebar) or topbar (Layout=Topbar) + content ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar nav -->
            <Border Grid.Column="0" Width="204" BorderBrush="{DynamicResource StrokeDividerBrush}" BorderThickness="0,0,1,0"
                    Visibility="{Binding Layout, Converter={StaticResource EnumToVisibility}, ConverterParameter=Sidebar}">
                <StackPanel Margin="0,8">
                    <RadioButton Style="{StaticResource NavButton}" GroupName="navSide" Content="{x:Static res:Strings.Nav_Record}" Tag="&#xE714;"
                                 Command="{Binding NavigateCommand}" CommandParameter="Record"
                                 IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Record, Mode=OneWay}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="navSide" Content="{x:Static res:Strings.Nav_Library}" Tag="&#xE8A9;"
                                 Command="{Binding NavigateCommand}" CommandParameter="Library"
                                 IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Library, Mode=OneWay}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="navSide" Content="{x:Static res:Strings.Nav_Schedule}" Tag="&#xE787;"
                                 Command="{Binding NavigateCommand}" CommandParameter="Schedule"
                                 IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Schedule, Mode=OneWay}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="navSide" Content="{x:Static res:Strings.Nav_Settings}" Tag="&#xE713;"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                 IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Settings, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!-- Content column (with optional top nav bar) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Top-bar nav -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource StrokeDividerBrush}" BorderThickness="0,0,0,1" Padding="14,7"
                        Visibility="{Binding Layout, Converter={StaticResource EnumToVisibility}, ConverterParameter=TopTab}">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource TopNavButton}" GroupName="navTop" Content="{x:Static res:Strings.Nav_Record}" Tag="&#xE714;"
                                     Command="{Binding NavigateCommand}" CommandParameter="Record"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Record, Mode=OneWay}" />
                        <RadioButton Style="{StaticResource TopNavButton}" GroupName="navTop" Content="{x:Static res:Strings.Nav_Library}" Tag="&#xE8A9;"
                                     Command="{Binding NavigateCommand}" CommandParameter="Library"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Library, Mode=OneWay}" />
                        <RadioButton Style="{StaticResource TopNavButton}" GroupName="navTop" Content="{x:Static res:Strings.Nav_Schedule}" Tag="&#xE787;"
                                     Command="{Binding NavigateCommand}" CommandParameter="Schedule"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Schedule, Mode=OneWay}" />
                        <RadioButton Style="{StaticResource TopNavButton}" GroupName="navTop" Content="{x:Static res:Strings.Nav_Settings}" Tag="&#xE713;"
                                     Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                     IsChecked="{Binding SelectedNav, Converter={StaticResource EnumToBool}, ConverterParameter=Settings, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" Margin="0" />

            <!-- Error/warning snackbar (§3.6 RecoverableWarning/BlockingError channel) -->
            <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,24"
                    Visibility="{Binding SnackbarVisible, Converter={StaticResource BoolToVisibility}}"
                    Background="{DynamicResource SurfaceAcrylicBrush}" BorderBrush="{DynamicResource StrokeCardBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,10" MaxWidth="620">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SnackbarIsError}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource CriticalBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding SnackbarMessage}" VerticalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="480" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Button Content="Dismiss" Command="{Binding DismissSnackbarCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="16,0,0,0" Height="28" />
                </StackPanel>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
