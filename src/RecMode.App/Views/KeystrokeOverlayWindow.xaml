<Window x:Class="RecMode.App.Views.KeystrokeOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False" ResizeMode="NoResize"
        IsHitTestVisible="False" Focusable="False" WindowStartupLocation="Manual">
    <Grid>
        <Border x:Name="Pill" Background="#D9202020" CornerRadius="10" Padding="18,11"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,72"
                Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="PillScale" ScaleX="0.92" ScaleY="0.92" />
            </Border.RenderTransform>
            <TextBlock x:Name="ComboText" Foreground="White" FontSize="20" FontWeight="SemiBold" />
        </Border>
    </Grid>
</Window>
