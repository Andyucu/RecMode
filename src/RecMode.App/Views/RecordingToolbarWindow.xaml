<Window x:Class="RecMode.App.Views.RecordingToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:RecMode.App.Resources"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual">
    <Border Background="{DynamicResource SurfaceAcrylicBrush}" BorderBrush="{DynamicResource StrokeCardBrush}"
            BorderThickness="1" CornerRadius="8" Padding="10,6">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="RecDot" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{DynamicResource CriticalBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                <Setter Property="Fill" Value="#F7A400" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHealthy}" Value="False">
                                <Setter Property="Fill" Value="#F7A400" />
                            </DataTrigger>
                            <!-- Recording pulse (design: rm-blink 1.2s infinite — opacity 1 → 0.25, stops while paused) -->
                            <DataTrigger Binding="{Binding IsPaused}" Value="False">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="RecDotBlink">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.66" Value="0.25" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.2" Value="0.25" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="RecDotBlink" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>

            <TextBlock Text="{Binding ElapsedText}" Style="{StaticResource MonoText}" FontSize="13"
                       MinWidth="52" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />

            <Border Width="1" Height="18" Margin="8,0" Background="{DynamicResource StrokeCardBrush}" />

            <Button Command="{Binding PauseResumeCommand}" Content="{Binding PauseButtonText}"
                    ToolTip="Pause or resume the recording (F10)"
                    Style="{StaticResource SecondaryButton}" Height="28" MinWidth="72" Padding="10,0" />
            <Button Command="{Binding ScreenshotCommand}" Content="{x:Static res:Strings.Record_Screenshot}"
                    ToolTip="Save a still image of the current source (F11)"
                    Style="{StaticResource SecondaryButton}" Height="28" Padding="10,0" Margin="6,0,0,0" />
            <Button Command="{Binding ToggleAnnotateCommand}" Content="{x:Static res:Strings.Record_Annotate}"
                    ToolTip="Draw on screen while recording (Esc or F12 to exit, right-click to clear)"
                    Height="28" Padding="10,0" Margin="6,0,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnnotating}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Border Width="1" Height="18" Margin="8,0" Background="{DynamicResource StrokeCardBrush}" />

            <TextBlock Text="{Binding StatsText}" Style="{StaticResource CaptionText}"
                       VerticalAlignment="Center" MinWidth="140" />

            <Button Command="{Binding RecordCommand}" Content="{x:Static res:Strings.Record_Stop}"
                    ToolTip="Stop the recording (F9)"
                    Style="{StaticResource AccentButton}" Height="28" MinWidth="64" Padding="10,0" Margin="8,0,0,0" />
        </StackPanel>
    </Border>
</Window>
