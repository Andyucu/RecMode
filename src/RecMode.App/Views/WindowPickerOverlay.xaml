<Window x:Class="RecMode.App.Views.WindowPickerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        ShowInTaskbar="False" Topmost="True" Background="#33000000"
        FontFamily="{StaticResource AppFontFamily}"
        Cursor="Cross">
    <Grid>
        <Canvas x:Name="HighlightCanvas" Background="Transparent" IsHitTestVisible="False">
            <Rectangle x:Name="HighlightRect" Stroke="{DynamicResource AccentBrush}" StrokeThickness="3"
                       Fill="#2000AEEF" Visibility="Collapsed" />
            <Border x:Name="TitleLabel" Background="#E6202020" CornerRadius="4" Padding="8,4" Visibility="Collapsed">
                <TextBlock x:Name="TitleText" Foreground="White" FontSize="13" MaxWidth="480" TextTrimming="CharacterEllipsis" />
            </Border>
        </Canvas>

        <!-- Toolbar -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40"
                Background="#E6202020" CornerRadius="8" Padding="8" BorderBrush="#33FFFFFF" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Click a window to record it · Esc to cancel" Foreground="#C8FFFFFF"
                           VerticalAlignment="Center" Margin="8,0,16,0" FontSize="13" />
                <Button Content="Cancel" Click="OnCancel" Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
