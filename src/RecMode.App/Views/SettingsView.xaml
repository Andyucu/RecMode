<UserControl x:Class="RecMode.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:RecMode.App.Resources"
             xmlns:vm="clr-namespace:RecMode.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <!-- combo used across the encoding-defaults cards -->
        <Style x:Key="CardCombo" TargetType="ComboBox" BasedOn="{StaticResource AppComboBox}">
            <Setter Property="Width" Value="190" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- keyboard-shortcut key cap -->
        <Style x:Key="KeyCap" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeControlBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="{x:Static res:Strings.Nav_Settings}" Style="{StaticResource TitleText}" Margin="0,0,0,6" />

            <!-- ===== Appearance ===== -->
            <TextBlock Text="{x:Static res:Strings.Settings_Appearance}" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Settings_Theme}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_ThemeDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ComboBox Style="{StaticResource CardCombo}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                              HorizontalAlignment="Right" ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Settings_Accent}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_AccentDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ComboBox Style="{StaticResource CardCombo}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                              HorizontalAlignment="Right" ItemsSource="{Binding Accents}" SelectedItem="{Binding SelectedAccent}" />
                </Grid>
            </Border>

            <!-- ===== Encoding defaults ===== -->
            <TextBlock Text="{x:Static res:Strings.Settings_EncodingDefaults}" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Settings_Encoder}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_EncoderDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ComboBox Style="{StaticResource CardCombo}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                              HorizontalAlignment="Right" ItemsSource="{Binding Codecs}" SelectedItem="{Binding SelectedCodec}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Settings_Container}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_ContainerDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ComboBox Style="{StaticResource CardCombo}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                              HorizontalAlignment="Right" ItemsSource="{Binding Containers}" SelectedItem="{Binding SelectedContainer}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Settings_AudioFormat}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_AudioFormatDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ComboBox Style="{StaticResource CardCombo}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                              HorizontalAlignment="Right" ItemsSource="{Binding AudioCodecs}" SelectedItem="{Binding SelectedAudioCodec}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Strings.Settings_AudioBitrate}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_AudioBitrateDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ComboBox Style="{StaticResource CardCombo}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                              HorizontalAlignment="Right" ItemsSource="{Binding AudioBitrates}" SelectedItem="{Binding SelectedAudioBitrate}" />
                </Grid>
            </Border>

            <!-- ===== Output ===== -->
            <TextBlock Text="{x:Static res:Strings.Settings_Output}" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_SaveTo}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{Binding OutputFolder}" Style="{StaticResource SettingsCardDesc}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="{x:Static res:Strings.Settings_Browse}" Command="{Binding BrowseCommand}"
                            Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_Pattern}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_PatternDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <TextBox Grid.Column="1" Text="{Binding FilenamePattern, UpdateSourceTrigger=LostFocus}" Width="240"
                             Style="{StaticResource AppTextBox}" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- ===== Recording ===== -->
            <TextBlock Text="{x:Static res:Strings.Settings_Recording}" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_Countdown}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_CountdownDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding CountdownEnabled, Mode=TwoWay}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_Cursor}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_CursorDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding CaptureCursor, Mode=TwoWay}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_Clicks}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_ClicksDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding HighlightClicks, Mode=TwoWay}" />
                </Grid>
            </Border>

            <!-- ===== Hotkeys (read-only until the remap UI) ===== -->
            <TextBlock Text="{x:Static res:Strings.Settings_Hotkeys}" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Settings_KeyboardShortcuts}" Style="{StaticResource BodyStrongText}" />
                    <TextBlock Text="{x:Static res:Strings.Settings_HotkeysDesc}" Style="{StaticResource SettingsCardDesc}" Margin="0,2,0,8" />
                    <Grid Margin="0,4,0,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_HkStartStop}" VerticalAlignment="Center" />
                        <Border Style="{StaticResource KeyCap}" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding HotkeyStartStop}" Style="{StaticResource MonoText}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource StrokeCardBrush}" Margin="0,9" />
                    <Grid>
                        <TextBlock Text="{x:Static res:Strings.Settings_HkPauseResume}" VerticalAlignment="Center" />
                        <Border Style="{StaticResource KeyCap}" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding HotkeyPauseResume}" Style="{StaticResource MonoText}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource StrokeCardBrush}" Margin="0,9" />
                    <Grid>
                        <TextBlock Text="{x:Static res:Strings.Settings_HkScreenshot}" VerticalAlignment="Center" />
                        <Border Style="{StaticResource KeyCap}" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding HotkeyScreenshot}" Style="{StaticResource MonoText}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== General ===== -->
            <TextBlock Text="{x:Static res:Strings.Settings_General}" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_Startup}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{x:Static res:Strings.Settings_StartupDesc}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{x:Static res:Strings.Settings_Updates}" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="{Binding VersionInfo}" Style="{StaticResource SettingsCardDesc}" />
                    </StackPanel>
                    <ToggleButton Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding CheckForUpdates, Mode=TwoWay}" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
