<UserControl x:Class="RecMode.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:RecMode.App.Resources"
             xmlns:vm="clr-namespace:RecMode.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="{x:Static res:Strings.Nav_Settings}" Style="{StaticResource TitleText}" Margin="0,0,0,16" />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Settings_Appearance}" Style="{StaticResource BodyStrongText}" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="{x:Static res:Strings.Settings_Theme}" VerticalAlignment="Center" />
                        <ComboBox Style="{StaticResource AppComboBox}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                                  Width="200" HorizontalAlignment="Right"
                                  ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" />
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{x:Static res:Strings.Settings_Accent}" VerticalAlignment="Center" />
                        <ComboBox Style="{StaticResource AppComboBox}" ItemContainerStyle="{StaticResource AppComboBoxItem}"
                                  Width="200" HorizontalAlignment="Right"
                                  ItemsSource="{Binding Accents}" SelectedItem="{Binding SelectedAccent}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Settings_Output}" Style="{StaticResource BodyStrongText}" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceInputBrush}" BorderBrush="{DynamicResource StrokeControlBrush}"
                                BorderThickness="1" CornerRadius="4" Height="32" Margin="0,0,8,0">
                            <TextBlock Text="{Binding OutputFolder}" VerticalAlignment="Center" Margin="10,0"
                                       TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Border>
                        <Button Grid.Column="1" Content="{x:Static res:Strings.Settings_Browse}" Command="{Binding BrowseCommand}"
                                Style="{StaticResource SecondaryButton}" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
