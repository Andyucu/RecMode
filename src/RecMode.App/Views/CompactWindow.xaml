<Window x:Class="RecMode.App.Views.CompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:RecMode.App.Resources"
        Title="RecMode"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="True" ResizeMode="NoResize"
        SizeToContent="Height" Width="392" WindowStartupLocation="Manual">
    <Border Background="{DynamicResource SurfaceCardBrush}" BorderBrush="{DynamicResource StrokeCardBrush}"
            BorderThickness="1" CornerRadius="8" Padding="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="48" ShadowDepth="16" Opacity="0.3" Color="Black" Direction="270" />
        </Border.Effect>
        <StackPanel>
            <!-- Header: app icon/title + theme toggle + expand -->
            <Grid Margin="0,0,0,12" MouseLeftButtonDown="OnHeaderDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="pack://application:,,,/Assets/AppIcon.ico" Width="18" Height="18" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="RecMode" Style="{StaticResource BodyStrongText}"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
                <Button Grid.Column="2" Content="◐" Command="{Binding ToggleThemeCommand}" ToolTip="Toggle theme"
                        AutomationProperties.Name="Toggle theme"
                        Style="{StaticResource SecondaryButton}" Width="32" Height="32" Padding="0" />
                <Button Grid.Column="3" Content="Expand" Command="{Binding ExpandCommand}"
                        ToolTip="Expand to full window" AutomationProperties.Name="Expand to full window"
                        Style="{StaticResource SecondaryButton}" Height="32" Padding="10,0" Margin="6,0,0,0" />
            </Grid>

            <!-- Source tiles -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Column="0" Style="{StaticResource CompactSourceTile}" GroupName="compact-src" Tag="&#xE7F4;"
                             IsChecked="{Binding Record.IsScreenSource, Mode=TwoWay}"
                             ToolTip="{x:Static res:Strings.Source_Screen}"
                             AutomationProperties.Name="{x:Static res:Strings.Source_Screen}" />
                <RadioButton Grid.Column="2" Style="{StaticResource CompactSourceTile}" GroupName="compact-src" Tag="&#xE737;"
                             IsChecked="{Binding Record.IsWindowSource, Mode=TwoWay}"
                             ToolTip="{x:Static res:Strings.Source_Window}"
                             AutomationProperties.Name="{x:Static res:Strings.Source_Window}" />
                <RadioButton Grid.Column="4" Style="{StaticResource CompactSourceTile}" GroupName="compact-src" Tag="&#xEF20;"
                             IsChecked="{Binding Record.IsRegionSource, Mode=TwoWay}"
                             ToolTip="{x:Static res:Strings.Source_Region}"
                             AutomationProperties.Name="{x:Static res:Strings.Source_Region}" />
                <RadioButton Grid.Column="6" Style="{StaticResource CompactSourceTile}" GroupName="compact-src" Tag="&#xE960;"
                             IsChecked="{Binding Record.WebcamEnabled, Mode=TwoWay}"
                             IsEnabled="{Binding Record.HasWebcamDevices}"
                             ToolTip="{x:Static res:Strings.Source_Webcam}"
                             AutomationProperties.Name="{x:Static res:Strings.Source_Webcam}" />
            </Grid>

            <!-- Quick audio: System + Mic -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="System" Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center" Width="40" />
                <Slider Grid.Column="1" Style="{StaticResource AppSlider}" Minimum="0" Maximum="100"
                        Value="{Binding Record.SystemVolume, Mode=TwoWay}" Margin="6,0"
                        IsEnabled="{Binding Record.SystemAudioEnabled}"
                        AutomationProperties.Name="System audio volume" />
                <ToggleButton Grid.Column="2" IsChecked="{Binding Record.SystemAudioEnabled, Mode=TwoWay}"
                              Style="{StaticResource CompactAudioToggle}"
                              ToolTip="Enable/disable system audio" AutomationProperties.Name="System audio enabled" />
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Mic" Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center" Width="40" />
                <Slider Grid.Column="1" Style="{StaticResource AppSlider}" Minimum="0" Maximum="100"
                        Value="{Binding Record.MicVolume, Mode=TwoWay}" Margin="6,0"
                        IsEnabled="{Binding Record.MicEnabled}"
                        AutomationProperties.Name="Microphone volume" />
                <ToggleButton Grid.Column="2" IsChecked="{Binding Record.MicEnabled, Mode=TwoWay}"
                              Style="{StaticResource CompactAudioToggle}"
                              ToolTip="Enable/disable microphone" AutomationProperties.Name="Microphone enabled" />
            </Grid>

            <!-- Record / Screenshot + summary -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{Binding Record.RecordCommand}" Content="{Binding Record.RecordButtonText}"
                        Style="{StaticResource AccentButton}" Height="32" Padding="14,0" />
                <Button Grid.Column="1" Command="{Binding Record.ScreenshotCommand}" Content="{x:Static res:Strings.Record_Screenshot}"
                        Style="{StaticResource SecondaryButton}" Height="32" Padding="14,0" Margin="8,0,0,0" />
                <TextBlock Grid.Column="3" Text="{Binding Record.ElapsedText}" Style="{StaticResource MonoText}"
                           FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
