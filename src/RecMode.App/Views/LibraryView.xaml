<UserControl x:Class="RecMode.App.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:RecMode.App.Resources">
    <Grid Margin="24">
        <TextBlock Text="{x:Static res:Strings.Nav_Library}" Style="{StaticResource TitleText}" VerticalAlignment="Top" />
        <TextBlock Text="{Binding Message}" Style="{StaticResource BodyText}" Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</UserControl>
