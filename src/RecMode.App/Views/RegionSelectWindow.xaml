<Window x:Class="RecMode.App.Views.RegionSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        ShowInTaskbar="False" Topmost="True" Background="#66000000"
        FontFamily="{StaticResource AppFontFamily}"
        Cursor="Cross">
    <Grid>
        <Canvas x:Name="SelectionCanvas" Background="Transparent">
            <Rectangle x:Name="SelectionRect" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                       Fill="#20FFFFFF" Visibility="Collapsed" />
            <Border x:Name="SizeLabel" Background="#CC000000" CornerRadius="4" Padding="8,4" Visibility="Collapsed">
                <TextBlock x:Name="SizeText" Foreground="White" FontFamily="{StaticResource MonoFontFamily}" FontSize="13" />
            </Border>
        </Canvas>

        <!-- Toolbar -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40"
                Background="#E6202020" CornerRadius="8" Padding="8" BorderBrush="#33FFFFFF" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Drag to select a region · Esc to cancel · Enter to use" Foreground="#C8FFFFFF"
                           VerticalAlignment="Center" Margin="8,0,16,0" FontSize="13" />
                <Button Content="1920 × 1080" Click="OnPreset1080" Style="{StaticResource SecondaryButton}" Margin="0,0,6,0" Tag="1920x1080" />
                <Button Content="1280 × 720" Click="OnPreset720" Style="{StaticResource SecondaryButton}" Margin="0,0,6,0" Tag="1280x720" />
                <Button Content="Full" Click="OnPresetFull" Style="{StaticResource SecondaryButton}" Margin="0,0,16,0" />
                <Button Content="Cancel" Click="OnCancel" Style="{StaticResource SecondaryButton}" Margin="0,0,6,0" />
                <Button x:Name="ConfirmButton" Content="Use region" Click="OnConfirm" Style="{StaticResource AccentButton}" IsEnabled="False" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
