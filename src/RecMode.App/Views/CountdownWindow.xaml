<Window x:Class="RecMode.App.Views.CountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="#59000000"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="Manual" Focusable="True">
    <Grid>
        <Border x:Name="Bubble" Width="160" Height="160" CornerRadius="80"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#CC0A101C" BorderBrush="#40FFFFFF" BorderThickness="2"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="BubbleScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <TextBlock x:Name="Number" Text="3" FontSize="76" FontWeight="SemiBold"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontFamily="{StaticResource AppFontFamily}" />
        </Border>

        <TextBlock Text="Press Esc to cancel" Foreground="#B0FFFFFF" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,220,0,0" />
    </Grid>
</Window>
