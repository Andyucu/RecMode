<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light theme — ported from _ds/tokens/colors.css (WinUI 3 / Fluent). ARGB alphas baked to solid-ish values. -->

    <Color x:Key="WindowBackgroundColor">#F3F3F3</Color>
    <Color x:Key="SurfaceBaseColor">#F3F3F3</Color>
    <Color x:Key="SurfaceSecondaryColor">#EEEEEE</Color>
    <Color x:Key="SurfaceCardColor">#FBFBFB</Color>
    <Color x:Key="SurfaceInputColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAcrylicColor">#FCFCFC</Color>

    <Color x:Key="TextPrimaryColor">#E4000000</Color>
    <Color x:Key="TextSecondaryColor">#9B000000</Color>
    <Color x:Key="TextTertiaryColor">#72000000</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFFFF</Color>

    <Color x:Key="StrokeDividerColor">#15000000</Color>
    <Color x:Key="StrokeCardColor">#0F000000</Color>
    <Color x:Key="StrokeControlColor">#14000000</Color>
    <Color x:Key="SubtleHoverColor">#09000000</Color>
    <Color x:Key="SubtlePressedColor">#06000000</Color>

    <Color x:Key="CriticalColor">#C42B1C</Color>
    <Color x:Key="CautionColor">#9D5D00</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBaseColor}" />
    <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="{StaticResource SurfaceSecondaryColor}" />
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCardColor}" />
    <SolidColorBrush x:Key="SurfaceInputBrush" Color="{StaticResource SurfaceInputColor}" />
    <SolidColorBrush x:Key="SurfaceAcrylicBrush" Color="{StaticResource SurfaceAcrylicColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />
    <SolidColorBrush x:Key="StrokeDividerBrush" Color="{StaticResource StrokeDividerColor}" />
    <SolidColorBrush x:Key="StrokeCardBrush" Color="{StaticResource StrokeCardColor}" />
    <SolidColorBrush x:Key="StrokeControlBrush" Color="{StaticResource StrokeControlColor}" />
    <SolidColorBrush x:Key="SubtleHoverBrush" Color="{StaticResource SubtleHoverColor}" />
    <SolidColorBrush x:Key="SubtlePressedBrush" Color="{StaticResource SubtlePressedColor}" />
    <SolidColorBrush x:Key="CriticalBrush" Color="{StaticResource CriticalColor}" />
    <SolidColorBrush x:Key="CautionBrush" Color="{StaticResource CautionColor}" />
</ResourceDictionary>
